# Birgerik Core - 環境変数
# このファイルをコピーして .env.local を作成し、値を設定してください

# ============================================================
# Supabase（必須）
# Supabase Dashboard > Project Settings > API で確認
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# JWT（必須）
# Admin ログイン認証に使用。openssl rand -base64 32 などで生成
# ============================================================
JWT_SECRET=your-secret-key

# ============================================================
# CORS（本番環境では必須）
# birgerik-web の Vercel デプロイ URL を指定
# 複数ある場合はカンマ区切り
# 未設定時はすべてのオリジンを許可（開発用）
# ============================================================
# ALLOWED_ORIGINS=https://your-birgerik-web.vercel.app
