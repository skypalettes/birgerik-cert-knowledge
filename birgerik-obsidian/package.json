  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "study",
    "learning",
    "certification"
  ],
  "author": "Birgerik Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.10",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@birgerik/types": "file:../packages/types",
    "preact": "^10.19.3",
    "zustand": "^4.4.7"
  }
}
